{
  "name": "vuttik-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=vuttik-web",
    "dev:pos": "npm run dev --workspace=vuttik-pos-web",
    "build:web": "npm run build --workspace=vuttik-web",
    "build:pos": "npm run build --workspace=vuttik-pos-web"
  }
}
