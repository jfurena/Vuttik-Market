<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Proxy /api/ requests to Node.js backend on port 3005
  # LiteSpeed supports RewriteRule with [P] when mod_proxy is enabled
  RewriteCond %{REQUEST_URI} ^/api/
  RewriteRule ^api/(.*)$ http://127.0.0.1:3005/api/$1 [P,L]

  # SPA fallback: all other non-file requests go to index.html
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteRule . /index.html [L]
</IfModule>
