{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "dist-server",
    "rootDir": "server",
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": ["server/**/*.ts"]
}
