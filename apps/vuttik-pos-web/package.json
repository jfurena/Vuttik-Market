{
  "name": "vuttik-pos-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite --open\"",
    "server": "tsx server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.vuttik.pos",
    "productName": "Vuttik POS",
    "directories": {
      "output": "release/"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "icon": "public/vuttik-pos-logo.png"
    },
    "portable": {
      "artifactName": "${productName} Portable.${ext}"
    }
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/leaflet": "^1.9.21",
    "@types/nodemailer": "^8.0.1",
    "@types/sqlite3": "^3.1.11",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "dotenv": "^17.2.3",
    "ethers": "^6.16.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "firebase": "^12.12.0",
    "framer-motion": "^11.11.17",
    "helmet": "^8.2.0",
    "i18n-iso-countries": "^7.14.0",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "nodemailer": "^8.0.11",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "sqlite3": "^6.0.1",
    "tailwind-merge": "^3.6.0",
    "uuid": "^13.0.0",
    "vhost": "^3.0.2",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.19.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/vhost": "^3.0.10",
    "autoprefixer": "^10.4.21",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
